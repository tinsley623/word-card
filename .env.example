# LLM API 配置（支持 OpenAI / DeepSeek / 任何兼容 OpenAI 格式的 API）
VITE_LLM_API_KEY=sk-your-api-key-here
VITE_LLM_API_BASE=https://api.openai.com/v1
VITE_LLM_MODEL=gpt-4o

# DeepSeek 示例：
# VITE_LLM_API_KEY=sk-your-deepseek-key
# VITE_LLM_API_BASE=https://api.deepseek.com/v1
# VITE_LLM_MODEL=deepseek-chat

# Claude 需使用兼容代理（如 openrouter）：
# VITE_LLM_API_KEY=sk-or-v1-your-key
# VITE_LLM_API_BASE=https://openrouter.ai/api/v1
# VITE_LLM_MODEL=anthropic/claude-sonnet-4-20250514
